
# Supabase
VITE_SUPABASE_URL=https://TVUJ_PROJEKT.supabase.co
VITE_SUPABASE_ANON_KEY=TVUJ_ANON_KEY

# Meta Pixel — browser
# Pixel ID najdes v Meta Business Suite → Events Manager → Dataset
VITE_META_PIXEL_ID=1323004113206297

# Interni klic pro autentizaci CAPI edge funkce
# Hodnota se MUSI shodovat se secret INTERNAL_API_KEY nastavenym v Supabase
# Vygeneruj nahodny retezec, napr.: openssl rand -hex 32
VITE_META_CAPI_KEY=NAHODNY_DLUHY_KLIC_MIN_32_ZNAKU

# =============================================
# Nasledujici promenne patri POUZE do Supabase Secrets
# NIKDY je nepisuj do tohoto souboru s realnymi hodnotami
# =============================================
# META_PIXEL_ID=1323004113206297
# META_ACCESS_TOKEN=EAAC...  <-- CAPI Access Token, pouze v Supabase Secrets
# INTERNAL_API_KEY=          <-- stejna hodnota jako VITE_META_CAPI_KEY vyse
# META_TEST_EVENT_CODE=      <-- volitelne, pro testovani v Events Manageru
# META_DEBUG=true            <-- volitelne, zapne debug logy v edge funkci
# ALLOWED_ORIGIN=https://tvujweb.cz  <-- volitelne, omezi CORS na konkretni domen
